<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WorldShift Whiteboard</title>
<style>
:root {
  --bg:#f7f4ed;
  --ink:#263238;
  --muted:#6b7280;
  --line:#292524;
  --panel:#ffffff;
  --accent:#2563eb;
}
* { box-sizing:border-box; }
body {
  margin:0;
  font-family: "Yu Gothic", "Hiragino Sans", system-ui, sans-serif;
  background:var(--bg);
  color:var(--ink);
  overflow:hidden;
}
.toolbar {
  position:fixed;
  top:16px;
  left:16px;
  right:16px;
  z-index:50;
  display:flex;
  gap:8px;
  align-items:center;
  flex-wrap:wrap;
  padding:12px;
  background:rgba(255,255,255,.9);
  border:2px solid #e5e7eb;
  border-radius:18px;
  box-shadow:0 12px 30px rgba(0,0,0,.08);
  backdrop-filter: blur(10px);
}
.brand {
  font-weight:900;
  font-size:18px;
  margin-right:8px;
}
button, label.import {
  border:1px solid #d1d5db;
  background:#fff;
  border-radius:999px;
  padding:9px 13px;
  cursor:pointer;
  font-weight:700;
  color:#374151;
}
button:hover, label.import:hover { background:#f3f4f6; }
button.primary { background:#111827; color:#fff; border-color:#111827; }
button.blue { background:#2563eb; color:#fff; border-color:#2563eb; }
.hint {
  margin-left:auto;
  color:var(--muted);
  font-size:12px;
}
#boardWrap {
  width:100vw;
  height:100vh;
  overflow:auto;
  cursor:grab;
}
#board {
  position:relative;
  width:2450px;
  height:1850px;
  background-image:
    radial-gradient(#d7d3ca 1px, transparent 1px);
  background-size:24px 24px;
  transform-origin:0 0;
}
.title {
  position:absolute;
  top:84px;
  left:80px;
  font-size:34px;
  font-weight:900;
  letter-spacing:.02em;
}
.subtitle {
  position:absolute;
  top:128px;
  left:82px;
  color:#6b7280;
  font-size:15px;
}
.card {
  position:absolute;
  width:330px;
  min-height:230px;
  padding:15px 16px 18px;
  border:2px solid #2b2b2b;
  border-radius:18px;
  background:#fff;
  box-shadow:7px 7px 0 rgba(0,0,0,.12);
  cursor:move;
}
.card.selected {
  outline:4px solid rgba(37,99,235,.22);
}
.section {
  display:inline-block;
  font-size:12px;
  font-weight:900;
  padding:5px 9px;
  border:1px solid #111827;
  border-radius:999px;
  margin-bottom:8px;
  background:rgba(255,255,255,.7);
}
.card h3 {
  margin:0 0 8px;
  font-size:18px;
  line-height:1.35;
}
.card .body {
  font-size:13px;
  line-height:1.65;
  white-space:pre-wrap;
  outline:none;
}
.card h3[contenteditable], .section[contenteditable], .body[contenteditable] {
  cursor:text;
}
.resize {
  position:absolute;
  right:8px;
  bottom:8px;
  width:16px;
  height:16px;
  border-right:3px solid #111827;
  border-bottom:3px solid #111827;
  cursor:nwse-resize;
}
.arrowLayer {
  position:absolute;
  inset:0;
  pointer-events:none;
  overflow:visible;
}
.note {
  position:absolute;
  width:260px;
  min-height:100px;
  padding:14px;
  border:2px dashed #111827;
  border-radius:18px;
  background:#fff;
  box-shadow:5px 5px 0 rgba(0,0,0,.1);
  cursor:move;
}
.note .body { outline:none; white-space:pre-wrap; line-height:1.6; font-size:14px; }
.mini {
  font-size:12px;
  color:#6b7280;
}
input[type=file] { display:none; }
</style>
</head>
<body>
<div class="toolbar">
  <div class="brand">🌍 WorldShift Whiteboard</div>
  <button class="primary" onclick="addCard()">＋ 枠を追加</button>
  <button onclick="addNote()">＋ メモ追加</button>
  <button class="blue" onclick="connectSelected()">➡ 選択した2枠を矢印で接続</button>
  <button onclick="saveBoard()">保存</button>
  <button onclick="loadBoard()">読み込み</button>
  <button onclick="exportJSON()">JSON出力</button>
  <label class="import">JSON読込<input type="file" id="importFile" accept=".json" onchange="importJSON(event)"></label>
  <button onclick="resetBoard()">初期状態に戻す</button>
  <span class="hint">操作：ドラッグ移動｜文字クリックで編集｜2枠選択して矢印｜右下でサイズ変更</span>
</div>

<div id="boardWrap">
  <div id="board">
    <svg class="arrowLayer" id="arrows">
      <defs>
        <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="#292524"></polygon>
        </marker>
      </defs>
    </svg>
    <div class="title" contenteditable="true">Amazon輸出ロードマップ</div>
    <div class="subtitle" contenteditable="true">準備 → リサーチ → 仕入れ → 発送 → 在庫管理 → 利益最大化</div>
  </div>
</div>

<script>
const initialCards = [{"id": "card1", "section": "Amazonで売る準備をする", "title": "Amazon輸出で必要なもの", "body": "・Amazon販売アカウント（セラーセントラル）\n商品を販売するためのアカウント。\n・海外口座\n米Amazonでの売上の受け取り用。\n・インポーター　💡発送代行サービスで解決！\n米FBA倉庫に商品を輸出する際の、米国側の輸入責任者。\n・返送先アメリカ住所　💡発送代行サービスで解決！\n米FBA倉庫からの返品や返送時に使う米国内住所。\n\n★Amazon輸出についてAIに相談 or SLCに相談（人）\n★準備から販売までSHiFT塾で進める", "x": 80, "y": 150, "color": "#fff5d9"}, {"id": "card2", "section": "Amazonで売る準備をする", "title": "アカウントを作成する", "body": "💡登録情報は必ず一致させましょう\n本人確認書類・海外口座・セラーアカウントの「氏名・住所・生年月日」表記は、すべて完全に一致させてください。\nズレがあるとアカウントが作成できない場合があります。\n\n▶国内Amazonアカウントを持っている\n「グローバルセリング」から米国ストアを追加\n※Amazonは重複アカウントを厳しく管理しているため、同一名義で無断で複数の販売アカウントを作成することは推奨されません。\n\n① Amazon.co.jpのセラーセントラルへログイン\n② 「グローバルセリング（Sell Globally）」へ進む\n③ 「アメリカ」を選択して販売地域を追加\n④ 不足している情報を入力\n✅事業者情報\n✅海外口座情報\n✅クレジットカード情報\n✅税務情報\n⑤ 審査完了・販売開始\n\n★アカウント作成をAIに相談 or SLCに相談（人）\n\n▶国内Amazonアカウントを持っていない\n① https://sell.amazon.com/へアクセスし、「販売を開始する」をクリック\n② 個人・法人を選択する\n③ 基本情報を入力する\n④ 売上受取用の海外口座を登録する\n⑤ クレジットカードを登録する\n⑥ 本人確認書類を提出する\n【個人の場合】パスポートまたは運転免許証／住所確認書類\n【法人の場合】登記簿謄本／代表者の本人確認書類\n⑦ 審査完了を待つ\n審査期間の目安：数日〜1週間程度\n\n★アカウント作成をAIに相談 or SLCに相談（人）", "x": 80, "y": 510, "color": "#fff5d9"}, {"id": "card3", "section": "売れる商品を見つける", "title": "リサーチツールを用意する", "body": "売りたい商品の売れ筋チェック・FBAでの手数料計算・販売価格のチェックなど、リサーチするために必要なツールを準備しましょう。\n\n・Keepa（有料版推奨）\n・FBA料金シミュレーター\n・その他ツールはコミュニティサイトでチェック 🖋️", "x": 470, "y": 150, "color": "#e9f7ff"}, {"id": "card4", "section": "売れる商品を見つける", "title": "リサーチ", "body": "①売れているジャンルを探す\n米国Amazonで「Japan Import」などで検索し、日本人セラーの商品を確認。\n\n②売れているセラーを深掘りする\nストアフロントを開き、出品商品を次々と確認していきます。\n\n③販売数を確認する\nKeepaのドロップ数で月間販売数の目安を把握。価格の安定性・出品者数の急増有無も確認。\n\n④利益計算をする\n販売価格ー手数料ー送料ー仕入れ価格ー関税で利益を確認します。\n\n★リサーチツール『profinder』で利益計算が簡単に！まずは無料でお試しください", "x": 470, "y": 510, "color": "#e9f7ff"}, {"id": "card5", "section": "売れる商品を見つける", "title": "仕入れ可否のチェック", "body": "輸出・FBA納品が出来るか、規制対象の商品でないかを確認しましょう。\n\n▶米国規制品\n・CPSC規制対象：12歳以下向けのおもちゃ・商品など\n・FDA申請が必要なもの：食品や化粧品、医療機器など\n\n▶FBA規制品\n・知財該当商品\n・ブランド申請・カテゴリー申請が必要な商品\n・リチウム電池・ボタン電池を含む商品\n・中古開封済の食品・化粧品\n\n▶その他要注意製品\n・航空搭載不可のもの：ガスボンベ・ライター\n\n詳しくはこちらをチェック 🖋️\n\n★発送商品についてAIに相談 or SLCに相談（人）\n★発送代行を利用して仕入れ可否をスムーズに！\n★発送代行をご利用の会員様は知財や発送不可の商品を事前に共有！", "x": 470, "y": 870, "color": "#e9f7ff"}, {"id": "card6", "section": "商品仕入れ＆納品準備", "title": "商品をAmazonへ登録する", "body": "セラーセントラルにて商品登録を行います。\n\n✅商品コンディション\n✅SKUの設定（自動割当可能）\n✅発送元はAmazonかAmazon以外か\n✅販売価格\n\n★発送商品についてAIに相談 or SLCに相談（人）", "x": 860, "y": 150, "color": "#ecfdf3"}, {"id": "card7", "section": "商品仕入れ＆納品準備", "title": "仕入・検品する", "body": "①Amazonにて商品登録した商品をECサイトや実店舗などで購入します。\n②届いた商品に破損等不備がないか検品をします。", "x": 860, "y": 510, "color": "#ecfdf3"}, {"id": "card8", "section": "商品仕入れ＆納品準備", "title": "商品を梱包＆保管をする", "body": "①Amazonのルールに沿って1商品ずつ梱包していきます。\n輸送中の破損やパッケージからの飛び出しを防ぐため、必要に応じて緩衝材やマスキングテープでの梱包がオススメ。\n\n梱包ルールについてはこちらをチェック 🖋️\n\n②FBA発送するまでは仕入れた商品を保管します。\n\n★発送代行で商品の受け取りから保管までまとめてお任せ！", "x": 860, "y": 870, "color": "#ecfdf3"}, {"id": "card9", "section": "発送準備", "title": "納品プランの作成・ラベル貼付", "body": "①セラーセントラル在庫管理画面から「Amazonから出荷」をクリック。\n②梱包方法・数量を入力。\n③FNSKUラベルを印刷しJANコードを隠すように貼付します。\n\n注意事項：\nAmazonでの受領処理時の読み取り間違いを防ぐため、FNSKUラベル以外のJANコードやQRコードは隠しておく必要があります。\n\n★発送代行でプラン作成・ラベル貼りまでまとめてお任せ！", "x": 1250, "y": 150, "color": "#fff0f6"}, {"id": "card10", "section": "発送準備", "title": "輸送箱・FBAラベルの準備", "body": "①納品プランに含めた商品を輸送用の段ボールに梱包します。\n②納品プラン上で箱サイズ・重量を入力。\n③納品期間の設定（到着予定期間を選択します）\n④配送業者を選択する\n出荷日・配送業者（個口配送）を選択し、輸送箱ラベルを印刷して貼付します。\n⑤FBAラベルの発行\n輸送する段ボールの側面に貼り付けます。\n\n★納品プランについてAIに相談 or SLCに相談（人）", "x": 1250, "y": 510, "color": "#fff0f6"}, {"id": "card11", "section": "発送準備", "title": "インボイス・添付書類・送り状の作成", "body": "①納品プランの作成が完了したら発送用の書類を作成します。\n\n必要な書類：\n・送り状\n・通関に必要な書類（インボイス・各種フォーム）\n\n注意事項：\n関税の支払い設定は必ず「発送人払い（DDP）」に。\n受取人払いのまま出荷すると米国Amazon倉庫で100%受領拒否されます。\n\n②配送会社へ引き渡す\n送り状を発行したら追跡番号を納品プランに入力します。\n集荷依頼をして引き渡しましょう。\n\n受領後はAmazonが24時間365日販売してくれます。\n\n★発送代行で書類作成・集荷までまとめてお任せ！", "x": 1250, "y": 870, "color": "#fff0f6"}, {"id": "card12", "section": "発送準備", "title": "輸送状況の確認・通関対応", "body": "発送した荷物について、税関から突然の問い合わせや追加書類の提出を求められることがあります。\n必要に応じて、書類の提出などの対応が必要です。\n\n★発送代行では専門のスタッフが代わりに責任をもって対応いたします。\n★輸出トラブルの緊急対応サポート", "x": 1250, "y": 1230, "color": "#fff0f6"}, {"id": "card13", "section": "在庫管理と価格最適化", "title": "在庫確認", "body": "発送した商品がFBA倉庫にちゃんと届いて在庫補充されたか確認する。\n\n▶FBAに届いてはいるけど在庫に反映されないときの対応\nFBA倉庫に到着してから在庫に反映されたか確認しましょう。\n在庫に反映されない場合は、倉庫内での紛失の可能性があります。\nAmazonに申請し承認されれば補填されます。\n\n詳しくはこちらをチェック 🖋️", "x": 1640, "y": 150, "color": "#f3efff"}, {"id": "card14", "section": "在庫管理と価格最適化", "title": "価格最適化", "body": "BUYBOXに合わせよう\n\n▶BUYBOXについて\nAmazonで相乗り出品をする場合は、Buy Box（カート）の獲得が重要です。\nカートを獲得しやすくするために、まずは現在のカート価格に合わせて価格設定を行いましょう。\n\n★WorldShiftでは、自動価格改定システムも取り揃えております。\n詳しくはこちらをチェック 🖋️", "x": 1640, "y": 510, "color": "#f3efff"}, {"id": "card15", "section": "利益を伸ばす", "title": "副産物の活用", "body": "FBA発送をすることで得られる利益はAmazonからの売上金だけではありません💡\n\n例えば・・・\n・ECサイトと提携しているポイントサイトで得られるポイント\n・仕入れをする際に使用するECサイトで得られるポイント\n・支払に使用するクレジットカードのポイントやマイル\n\nこれらを活用することで次の仕入れに活かすこともできます！\n\n★クレカコンサルで副産物を最大化", "x": 2030, "y": 150, "color": "#fff7ed"}, {"id": "card16", "section": "利益を伸ばす", "title": "売上管理", "body": "物販は利益が出ていても資金が回らず「黒字倒産」のような状態になることがあります。\n管理シートを作成またはツールを活用してお金の流れを常に把握できる状態にしておきましょう。\n\n①セラセンにて売上レポートを取得して確認します。\n・売上情報：何が何個いくらで売れたか\n・Amazon手数料：販売手数料・納品手数料・保管料・返品返金に関する手数料\n\n②商品原価の計算\n・仕入価格\n・国内送料\n・梱包費用\n・国際送料\n・関税\n\n③セラセンにて在庫レポートを取得して在庫・返品・補填情報を確認し、回転率や返品率を計算します。\n回転率の高いものは在庫数を増やすなど検討が出来ます。\n返品率の高いものは追加の仕入れを控えることも検討が出来ます。\n\n★キャッシュフロー・在庫管理シートを取得\n★売上管理・利益を伸ばすことにお悩みの方へのサポート", "x": 2030, "y": 510, "color": "#fff7ed"}];
let cards = [];
let arrows = [];
let selected = [];
let idSeq = 1000;

const board = document.getElementById('board');
const arrowSvg = document.getElementById('arrows');

function init() {
  cards = initialCards.map(c => ({...c, w:330, h:null, type:'card'}));
  arrows = [];
  render();
  autoConnect();
}
function autoConnect() {
  const bySection = {};
  cards.forEach(c => {
    bySection[c.section] ??= [];
    bySection[c.section].push(c);
  });
  cards.forEach((c, i) => {
    if (i < cards.length - 1) arrows.push({from:c.id, to:cards[i+1].id});
  });
  drawArrows();
}

function render() {
  document.querySelectorAll('.card,.note').forEach(el => el.remove());
  cards.forEach(makeElement);
  drawArrows();
}

function makeElement(c) {
  const el = document.createElement('div');
  el.className = c.type === 'note' ? 'note' : 'card';
  el.id = c.id;
  el.style.left = c.x + 'px';
  el.style.top = c.y + 'px';
  el.style.width = (c.w || 330) + 'px';
  if(c.h) el.style.height = c.h + 'px';
  if(c.color && c.type !== 'note') el.style.background = c.color;

  if(c.type === 'note') {
    el.innerHTML = `<div class="body" contenteditable="true">${escapeHtml(c.body || 'メモを入力')}</div><div class="resize"></div>`;
  } else {
    el.innerHTML = `
      <div class="section" contenteditable="true">${escapeHtml(c.section)}</div>
      <h3 contenteditable="true">${escapeHtml(c.title)}</h3>
      <div class="body" contenteditable="true">${escapeHtml(c.body)}</div>
      <div class="resize"></div>`;
  }

  board.appendChild(el);
  el.addEventListener('pointerdown', onPointerDown);
  el.addEventListener('click', e => selectCard(c.id, e.shiftKey || e.ctrlKey));
  el.addEventListener('input', () => syncText(c.id));
  el.querySelector('.resize').addEventListener('pointerdown', resizeStart);
}

function syncText(id) {
  const el = document.getElementById(id);
  const c = cards.find(x => x.id === id);
  if(!c || !el) return;
  if(c.type === 'note') {
    c.body = el.querySelector('.body').innerText;
  } else {
    c.section = el.querySelector('.section').innerText;
    c.title = el.querySelector('h3').innerText;
    c.body = el.querySelector('.body').innerText;
  }
}

function selectCard(id, multi=false) {
  if(!multi) selected = [];
  if(selected.includes(id)) selected = selected.filter(x => x !== id);
  else selected.push(id);
  if(selected.length > 2) selected.shift();
  document.querySelectorAll('.card,.note').forEach(el => el.classList.remove('selected'));
  selected.forEach(s => document.getElementById(s)?.classList.add('selected'));
}

let drag = null;
function onPointerDown(e) {
  if(e.target.isContentEditable || e.target.classList.contains('resize')) return;
  const el = e.currentTarget;
  const c = cards.find(x => x.id === el.id);
  drag = {id:el.id, startX:e.clientX, startY:e.clientY, x:c.x, y:c.y};
  el.setPointerCapture(e.pointerId);
  document.addEventListener('pointermove', onPointerMove);
  document.addEventListener('pointerup', onPointerUp);
}
function onPointerMove(e) {
  if(!drag) return;
  const c = cards.find(x => x.id === drag.id);
  c.x = drag.x + (e.clientX - drag.startX);
  c.y = drag.y + (e.clientY - drag.startY);
  const el = document.getElementById(c.id);
  el.style.left = c.x + 'px';
  el.style.top = c.y + 'px';
  drawArrows();
}
function onPointerUp() {
  drag = null;
  document.removeEventListener('pointermove', onPointerMove);
  document.removeEventListener('pointerup', onPointerUp);
}

let resizing = null;
function resizeStart(e) {
  e.stopPropagation();
  const el = e.target.parentElement;
  const c = cards.find(x => x.id === el.id);
  resizing = {id:c.id, startX:e.clientX, startY:e.clientY, w:el.offsetWidth, h:el.offsetHeight};
  document.addEventListener('pointermove', resizeMove);
  document.addEventListener('pointerup', resizeEnd);
}
function resizeMove(e) {
  if(!resizing) return;
  const c = cards.find(x => x.id === resizing.id);
  c.w = Math.max(220, resizing.w + e.clientX - resizing.startX);
  c.h = Math.max(120, resizing.h + e.clientY - resizing.startY);
  const el = document.getElementById(c.id);
  el.style.width = c.w + 'px';
  el.style.height = c.h + 'px';
  drawArrows();
}
function resizeEnd() {
  resizing = null;
  document.removeEventListener('pointermove', resizeMove);
  document.removeEventListener('pointerup', resizeEnd);
}

function addCard() {
  const id = 'card' + idSeq++;
  cards.push({
    id, type:'card', section:'新しいセクション', title:'新しい項目',
    body:'ここに内容を入力してください。', x:120 + Math.random()*300, y:180 + Math.random()*300, w:330, color:'#ffffff'
  });
  render();
}
function addNote() {
  const id = 'note' + idSeq++;
  cards.push({id, type:'note', body:'メモを入力', x:160 + Math.random()*300, y:220 + Math.random()*300, w:260});
  render();
}

function connectSelected() {
  if(selected.length !== 2) {
    alert('矢印でつなぎたい枠を2つ選択してください。Shift/Ctrlクリックで複数選択できます。');
    return;
  }
  arrows.push({from:selected[0], to:selected[1]});
  drawArrows();
}

function drawArrows() {
  arrowSvg.querySelectorAll('path').forEach(p => p.remove());
  arrows.forEach(a => {
    const from = document.getElementById(a.from);
    const to = document.getElementById(a.to);
    if(!from || !to) return;
    const x1 = from.offsetLeft + from.offsetWidth;
    const y1 = from.offsetTop + from.offsetHeight/2;
    const x2 = to.offsetLeft;
    const y2 = to.offsetTop + to.offsetHeight/2;
    const mid = Math.max(40, (x2-x1)/2);
    const path = document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d', `M ${x1} ${y1} C ${x1+mid} ${y1}, ${x2-mid} ${y2}, ${x2} ${y2}`);
    path.setAttribute('stroke','#292524');
    path.setAttribute('stroke-width','3');
    path.setAttribute('fill','none');
    path.setAttribute('marker-end','url(#arrowhead)');
    path.setAttribute('stroke-linecap','round');
    arrowSvg.appendChild(path);
  });
}

function boardState() {
  document.querySelectorAll('.card,.note').forEach(el => syncText(el.id));
  return {
    cards, arrows,
    title: document.querySelector('.title').innerText,
    subtitle: document.querySelector('.subtitle').innerText
  };
}
function saveBoard() {
  localStorage.setItem('worldshift_whiteboard', JSON.stringify(boardState()));
  alert('保存しました。');
}
function loadBoard() {
  const raw = localStorage.getItem('worldshift_whiteboard');
  if(!raw) return alert('保存データがありません。');
  applyState(JSON.parse(raw));
}
function applyState(state) {
  cards = state.cards || [];
  arrows = state.arrows || [];
  document.querySelector('.title').innerText = state.title || 'Amazon輸出ロードマップ';
  document.querySelector('.subtitle').innerText = state.subtitle || '';
  render();
}
function exportJSON() {
  const blob = new Blob([JSON.stringify(boardState(), null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'worldshift-whiteboard.json';
  a.click();
}
function importJSON(e) {
  const file = e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = () => applyState(JSON.parse(reader.result));
  reader.readAsText(file);
}
function resetBoard() {
  if(confirm('初期状態に戻しますか？現在の編集内容は保存していない場合消えます。')) init();
}
function escapeHtml(str) {
  return String(str || '').replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[s]));
}

init();
</script>
</body>
</html>
